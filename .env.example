# swing-advisor 환경변수 예제
# 실제 값은 .env 에 저장하고 절대 커밋하지 말 것.
# Phase 1 에서는 외부 API 호출이 없으므로 키는 필요 없음.
# Phase 2 이후 활성화될 키들을 미리 안내한다.

# 운영 모드 (paper 만 허용. 실주문 모드는 금지)
MODE=paper

# 로깅
LOG_LEVEL=INFO

# 로컬 DB 경로
DB_PATH=data/db/swing.db

# Phase 2: 환율 API (예: exchangerate.host, 무료)
# FX_API_KEY=

# Phase 5: LLM (둘 중 하나 또는 둘 다)
# 발급: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# 발급: https://console.groq.com/keys
# GROQ_API_KEY=

# Phase 6: 텔레그램 봇
# 발급: @BotFather 봇 생성 후 토큰
# TELEGRAM_BOT_TOKEN=
# 본인 채팅 ID (https://api.telegram.org/bot<token>/getUpdates)
# TELEGRAM_CHAT_ID=

# Phase 2 검토: Turso (원격 SQLite)
# 발급: https://turso.tech (무료 티어)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# 면책
# 본 도구는 페이퍼 트레이딩 전용이며 실거래 결과를 보장하지 않는다.
# 모든 투자 책임은 사용자 본인에게 있다.
