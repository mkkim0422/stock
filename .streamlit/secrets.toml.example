# Streamlit secrets 예제
# 로컬: 이 파일을 secrets.toml 로 복사 후 값 채움 (gitignore 됨)
# Cloud: Streamlit Cloud 대시보드 > Settings > Secrets 에 직접 입력
# Phase 1 에서는 값이 비어 있어도 작동한다.

[app]
mode = "paper"
log_level = "INFO"

[db]
path = "data/db/swing.db"

